{
  "name": "myelin-core",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "dotenv -e .dev.vars -- drizzle-kit generate",
    "db:migrate": "dotenv -e .dev.vars -- drizzle-kit migrate",
    "db:push": "dotenv -e .dev.vars -- drizzle-kit push",
    "db:studio": "dotenv -e .dev.vars -- drizzle-kit studio",
    "db:generate:prod": "dotenv -e .prod.vars -- drizzle-kit generate",
    "db:migrate:prod": "dotenv -e .prod.vars -- drizzle-kit migrate",
    "db:push:prod": "dotenv -e .prod.vars -- drizzle-kit push",
    "db:studio:prod": "dotenv -e .prod.vars -- drizzle-kit studio"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.3.0",
    "@neondatabase/serverless": "^1.1.0",
    "@scalar/hono-api-reference": "^0.10.14",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "arctic": "^3.7.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "wrangler": "^4.4.0"
  }
}